# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://neondb_owner:***@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# Auth (better-auth)
BETTER_AUTH_SECRET=your-secret-key-min-32-chars-here
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth
# Development: Use localhost credentials
# Production (Vercel crm.maat.work):
#   - Client ID: 641908288178-937m4kvthd9m6jh59n3dg561bira535l.apps.googleusercontent.com
#   - Client Secret: Get from GCP Console (Credentials > MaatWork > Client secrets)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Sentry
SENTRY_DSN=

# App
NODE_ENV=development
PORT=3000
