# ============================================================
# GOOGLE OAUTH (NextAuth)
# ============================================================
# Obtener de: Google Cloud Console > APIs y Servicios > Credenciales
# Crear OAuth 2.0 Client ID tipo "Aplicación web"
#
# Authorized redirect URI:
#   Producción: https://tu-dominio.com/api/auth/callback/google
#   Desarrollo: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://crm.maat.work/api/auth/callback/google

# ============================================================
# NEXTAUTH (Autenticación NextAuth v4)
# ============================================================
# URL base de la aplicación (sin trailing slash)
NEXTAUTH_URL=https://crm.maat.work

# Secret para firmar JWTs de sesión
# Generar: openssl rand -base64 32
NEXTAUTH_SECRET=

# ============================================================
# ENCRIPTACIÓN DE TOKENS (AES-256-GCM)
# ============================================================
# KEY para encriptar tokens OAuth en JWT.
# NO es la clave de Google — es una clave AES local.
#
# Generar: openssl rand -hex 32
# Debe tener exactamente 64 caracteres (32 bytes en hex)
TOKEN_ENCRYPTION_KEY=

# ============================================================
# CRON JOBS (Sincronización de Calendario)
# ============================================================
# Secret para validar requests de CRON desde Vercel.
# Vercel envía header: x-cron-secret
#
# Generar: openssl rand -base64 32
CRON_SECRET=

# ============================================================
# WEBHOOK DE GOOGLE CALENDAR
# ============================================================
# Token para verificar requests del webhook de Google Calendar.
# Google lo envía en hub.verify_token al verificar el endpoint.
#
# Generar: openssl rand -hex 32
CALENDAR_WEBHOOK_VERIFY_TOKEN=

# ============================================================
# BASE DE DATOS
# ============================================================
# Desarrollo local (PostgreSQL):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/maatwork_crm?schema=public"

# Producción (Neon — Vercel Marketplace):
# El valor se provee automáticamente via integración de Vercel

# ============================================================
# JWT (Legacy — para el sistema de auth custom pre-existente)
# ============================================================
# Generar: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-min-32-characters

# ============================================================
# ENTORNO
# ============================================================
NODE_ENV=development
LOG_LEVEL=debug
LOG_ENABLE_CONSOLE=true

# ============================================================
# OPCIONAL: Sentry Error Tracking
# ============================================================
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_ORG=
# SENTRY_PROJECT=
