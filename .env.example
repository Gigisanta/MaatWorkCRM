# ===========================================
# MaatWork CRM - Environment Variables Template
# ===========================================
# INSTRUCCIONES:
# 1. Copia este archivo como .env.local: cp .env.example .env.local
# 2. Llena los valores de cada variable
# 3. NO subas .env.local a Git (ya está en .gitignore)

# ===========================================
# DATABASE (Producción - Neon PostgreSQL)
# ===========================================
# Estos valores se configuran automáticamente en Vercel via vercel env pull
# Locally, you can use SQLite for development:
# DATABASE_URL="file:///absolute/path/to/db/custom.db"

# Vercel Serverless Connection Pool (Neon PostgreSQL):
# El connection_limit=1 es CRÍTICO para serverless - evita agotar conexiones
DATABASE_URL="postgresql://user:password@host.neon.tech/neondb?sslmode=require&connection_limit=1&pool_timeout=10&connect_timeout=10"

# ===========================================
# GOOGLE OAUTH
# ===========================================
# Crear cliente OAuth en: https://console.cloud.google.com > APIs & Services > Credentials
# Crear OAuth 2.0 Client ID tipo "Web application"
# Agregar URI de redirección autorizada:
#   - http://localhost:3000/api/auth/callback/google (desarrollo)
#   - https://crm.maat.work/api/auth/callback/google (producción)
# Si la pantalla de consentimiento está en modo "Prueba", agregar usuarios de prueba
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET"

# ===========================================
# NEXTAUTH
# ===========================================
# Desarrollo:
NEXTAUTH_URL="http://localhost:3000"
# Producción: (descomentar y ajustar)
# NEXTAUTH_URL="https://crm.maat.work"

# Generar secret: openssl rand -base64 32
NEXTAUTH_SECRET="YOUR_NEXTAUTH_SECRET"

# ===========================================
# TOKEN ENCRYPTION (AES-256-GCM)
# ===========================================
# Generar key: openssl rand -hex 32 (64 caracteres hex = 32 bytes)
TOKEN_ENCRYPTION_KEY="YOUR_64_CHAR_HEX_KEY"

# ===========================================
# CRON JOBS
# ===========================================
# Generar secret: openssl rand -base64 32
CRON_SECRET="YOUR_CRON_SECRET"

# ===========================================
# GOOGLE CALENDAR WEBHOOK
# ===========================================
# Generar token: openssl rand -hex 32
CALENDAR_WEBHOOK_VERIFY_TOKEN="YOUR_WEBHOOK_VERIFY_TOKEN"

# ===========================================
# JWT SECRET (middleware)
# ===========================================
# Usado por middleware.ts para validación JWT legacy
# Generar secret: openssl rand -base64 32
JWT_SECRET="YOUR_JWT_SECRET"

# ===========================================
# UPSTASH REDIS (rate limiting)
# ===========================================
# Obtener de: https://console.upstash.com/
# O instalar via Vercel Marketplace: https://vercel.com/marketplace
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your_upstash_token"

# ===========================================
# DEVELOPMENT SETTINGS
# ===========================================
NODE_ENV=development
LOG_LEVEL=debug
LOG_ENABLE_CONSOLE=true
