# ===========================================
# MaatWork CRM - Environment Variables Template
# Copy to .env.local and fill in the values
# ===========================================

# ===========================================
# DATABASE
# ===========================================
# Local development (SQLite):
DATABASE_URL="file:///Users/prueba/Desktop/maatworkcrmv3/db/custom.db"

# Production Vercel (PostgreSQL via Neon) - fill from Vercel dashboard:
DATABASE_URL="postgresql://user:password@host:5432/db?schema=public&sslmode=require&connection_limit=1&pool_timeout=10"

# ===========================================
# GOOGLE OAUTH
# ===========================================
# Get from: Google Cloud Console > APIs & Services > Credentials
# Create OAuth 2.0 Client ID (Type: Web application)
# Add authorized redirect URIs:
#   - http://localhost:3000/api/auth/callback/google (development)
#   - https://crm.maat.work/api/auth/callback/google (production)
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET"

# ===========================================
# NEXTAUTH
# ===========================================
# Development:
NEXTAUTH_URL="http://localhost:3000"
# Production:
# NEXTAUTH_URL="https://crm.maat.work"

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="YOUR_NEXTAUTH_SECRET"

# ===========================================
# TOKEN ENCRYPTION (AES-256-GCM)
# Generate with: openssl rand -hex 32 (64 hex characters = 32 bytes)
# ===========================================
TOKEN_ENCRYPTION_KEY="YOUR_64_CHAR_HEX_KEY"

# ===========================================
# CRON JOBS
# Generate with: openssl rand -base64 32
# ===========================================
CRON_SECRET="YOUR_CRON_SECRET"

# ===========================================
# GOOGLE CALENDAR WEBHOOK
# Generate with: openssl rand -hex 32
# ===========================================
CALENDAR_WEBHOOK_VERIFY_TOKEN="YOUR_WEBHOOK_VERIFY_TOKEN"

# ===========================================
# JWT SECRET (middleware)
# Generate with: openssl rand -base64 32
# Used by middleware.ts for legacy JWT validation
# ===========================================
JWT_SECRET="YOUR_JWT_SECRET"

# ===========================================
# UPSTASH REDIS (for rate limiting)
# Get from: https://console.upstash.com/
# Or install via Vercel Marketplace: https://vercel.com/marketplace
# ===========================================
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your_upstash_token"

# ===========================================
# VERCEL (automatic)
# ===========================================
# VERCEL_URL="crm.maat.work" (set automatically by Vercel)

# ===========================================
# DEVELOPMENT SETTINGS
# ===========================================
NODE_ENV=development
LOG_LEVEL=debug
LOG_ENABLE_CONSOLE=true
