# ===========================================
# DATABASE CONFIGURATION
# ===========================================

## Local Development (PostgreSQL)
# Start PostgreSQL with Docker:
# docker run -d --name maatwork-postgres -e POSTGRES_USER=postgres -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=maatworkcrm -p 5432:5432 postgres:16
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/maatworkcrm?schema=public"

## Production (Neon via Vercel)
# When deployed to Vercel with Neon integration:
# - Vercel automatically provides DATABASE_URL from the Neon integration
# - No need to set this manually in production
# - The connection string will use ?sslmode=require

# ===========================================
# AUTHENTICATION
# ===========================================

# Generate with: openssl rand -base64 32
JWT_SECRET="your-jwt-secret-min-32-characters"

# ===========================================
# ENVIRONMENT
# ===========================================
NODE_ENV=development

# ===========================================
# LOGGING
# ===========================================
LOG_LEVEL=info
LOG_ENABLE_CONSOLE=true

# ===========================================
# OPTIONAL: Sentry Error Tracking
# ===========================================
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_ORG=
# SENTRY_PROJECT=

# ===========================================
# OPTIONAL: Google OAuth
# ===========================================
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
